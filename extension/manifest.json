{
  "manifest_version": 3,
  "name": "Tetorica Retro Tab Filter",
  "version": "0.1.0",
  "description": "Capture the current tab and preview it through a grayscale WebGL shader.",
  "permissions": ["activeTab", "tabCapture", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Retro Tab Filter"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.css", "viewer.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
