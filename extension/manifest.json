{
  "manifest_version": 3,
  "name": "Tetorica Retro Player",
  "version": "0.21.3",
  "description": "Capture the current tab and preview it with retro CRT video and lo-fi audio effects.",
  "homepage_url": "https://kyorohiro.itch.io/tetorica-retro-player",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage", "tabCapture", "scripting"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Open Tetorica Retro Player"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "viewer.css",
        "viewer.js",
        "overlayRuntime.js",
        "shared/filterShader.js",
        "shared/settings.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
