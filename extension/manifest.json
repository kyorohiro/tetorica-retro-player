{
  "manifest_version": 3,
  "name": "Tetorica Retro Tab Filter",
  "version": "0.1.0",
  "description": "Capture the current tab and preview it through a grayscale WebGL shader.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "storage", "tabCapture", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png"
    },
    "default_popup": "popup.html",
    "default_title": "Open Retro Tab Filter"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.css", "viewer.js", "shared/filterShader.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
