{
  "name": "tetorica-retro-player",
  "private": true,
  "version": "0.41.3",
  "type": "module",
  "scripts": {
    "dev": "node scripts/build-sw.mjs && node scripts/sync-extension-shader.mjs && vite",
    "build": "node scripts/build-sw.mjs && node scripts/sync-extension-shader.mjs && tsc && vite build",
    "build:web": "tsc && vite build --config vite.web.config.ts",
    "build:extension": "node scripts/sync-extension-shader.mjs && node scripts/sync-extension-presets.mjs && node scripts/package-extension.mjs",
    "sync:extension-presets": "node scripts/sync-extension-presets.mjs",
    "build:doc": "node scripts/build-doc.mjs",
    "build:licenses": "node scripts/build-licenses.mjs",
    "version:set": "node scripts/set-version.mjs",
    "test": "vitest run",
    "preview": "vite preview",
    "tauri": "tauri",
    "dev:tauri": "npx tauri dev",
    "dev:tauri-sidecar": "npx tauri dev --config src-tauri/tauri.ffmpeg.conf.json -- --features ffmpeg-sidecar",
    "build:tauri": "npx tauri build",
    "build:tauri-sidecar": "npx tauri build --config src-tauri/tauri.ffmpeg.conf.json -- --features ffmpeg-sidecar"
  },
  "dependencies": {
    "@buildyourwebapp/tauri-plugin-sharesheet": "^0.0.1",
    "@choochmeque/tauri-plugin-sharekit-api": "^0.3.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@zip.js/zip.js": "^2.8.26",
    "heic2any": "^0.0.4",
    "hls.js": "^1.6.16",
    "lucide-react": "^1.17.0",
    "node-unrar-js": "^2.0.2",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-reader": "^0.20.4",
    "tone": "^15.1.22"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@tauri-apps/cli": "^2",
    "@types/howler": "^2.2.13",
    "@types/node": "^25.9.3",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
