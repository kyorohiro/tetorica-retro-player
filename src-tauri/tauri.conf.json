{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tetorica-retro-player",
  "version": "0.37.4",
  "identifier": "net.tetorica.retro-player",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "tetorica-retro-player",
        "width": 800,
        "height": 600,
        "dragDropEnabled": true,
        "useHttpsScheme": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      { "ext": ["mp4", "m4v", "mov", "mkv", "avi", "wmv", "flv", "webm", "ts", "m2ts", "ogv"], "name": "Video" },
      { "ext": ["mp3", "wav", "ogg", "m4a", "aac", "flac", "opus"], "name": "Audio" },
      { "ext": ["png", "jpg", "jpeg", "webp", "gif", "avif"], "name": "Image" }
    ]
  }
}
